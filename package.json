{
  "name": "skillscraft-hub",
  "private": true,
  "description": "Marketplace for AI Agent Skills, Prompts, Agents, and MCP servers",
  "scripts": {
    "build": "node scripts/build.mjs",
    "validate": "node scripts/validate-skills.mjs",
    "security": "node scripts/security-scan.mjs",
    "test": "node --test scripts/validate-skills.test.mjs",
    "test:e2e": "pnpm exec playwright test",
    "serve": "npx serve dist -l 3333",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@skillscraft/core": "^0.9.0",
    "@playwright/test": "^1.59.1",
    "serve": "^14.2.6"
  },
  "pnpm": {
    "overrides": {
      "@skillscraft/spec": "^0.9.0"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.8.1"
}
